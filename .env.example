# LLM Configuration 
# Pilih salah satu provider dan isi API key-nya.
# Uncomment (hapus #) provider yang ingin dipakai.

# --- GROQ (Gratis, super cepat) ---
LLM_PROVIDER=groq
LLM_API_KEY=isi_groq_api_key_kamu
LLM_MODEL=llama-3.3-70b-versatile
LLM_BASE_URL=https://api.groq.com/openai/v1

# --- OPENROUTER (Banyak model gratis) ---
# LLM_PROVIDER=openrouter
# LLM_API_KEY=isi_openrouter_api_key_kamu
# LLM_MODEL=meta-llama/llama-3.3-70b-instruct:free
# LLM_BASE_URL=https://openrouter.ai/api/v1

# --- GEMINI (via OpenAI-compatible endpoint) ---
# LLM_PROVIDER=gemini
# LLM_API_KEY=isi_gemini_api_key_kamu
# LLM_MODEL=gemini-2.0-flash
# LLM_BASE_URL=https://generativelanguage.googleapis.com/v1beta/openai/

# --- QWEN (via DashScope) ---
# LLM_PROVIDER=qwen
# LLM_API_KEY=isi_dashscope_api_key_kamu
# LLM_MODEL=qwen-plus
# LLM_BASE_URL=https://dashscope-intl.aliyuncs.com/compatible-mode/v1

# --- CUSTOM (LLM lain yang OpenAI-compatible) ---
# LLM_PROVIDER=custom
# LLM_API_KEY=isi_api_key_kamu
# LLM_MODEL=nama-model
# LLM_BASE_URL=https://api.example.com/v1

#  MongoDB Configuration
MONGODB_URI=isi_mongodb_connection_string_kamu
